{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "ReadDhanSsmParams",
            "Effect": "Allow",
            "Action": [
                "ssm:GetParameter",
                "ssm:GetParameters"
            ],
            "Resource": [
                "arn:aws:ssm:ap-south-1:*:parameter/nxbagger/DHAN_ACCESS_TOKEN",
                "arn:aws:ssm:ap-south-1:*:parameter/nxbagger/DHAN_TOKEN_EXPIRY"
            ]
        },
        {
            "Sid": "DecryptSecureStringWithAwsManagedKey",
            "Comment": "Only needed if the params use a customer-managed KMS key. The default SSM SecureString key (alias/aws/ssm) does not require an explicit grant for the instance role in most accounts — add/keep this statement if GetParameter fails with AccessDenied on decrypt.",
            "Effect": "Allow",
            "Action": "kms:Decrypt",
            "Resource": "arn:aws:kms:ap-south-1:*:key/*",
            "Condition": {
                "StringEquals": {
                    "kms:ViaService": "ssm.ap-south-1.amazonaws.com"
                }
            }
        }
    ]
}
