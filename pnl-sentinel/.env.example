# ── Telegram ────────────────────────────────────────────────
# Get the token from @BotFather. Get your chat id from @userinfobot.
# Use a DEDICATED bot (one long-poll consumer per token) — do not share a bot
# token with another running app, or Telegram returns 409 Conflict on getUpdates.
TELEGRAM_BOT_TOKEN=123456789:AA...your-token...
TELEGRAM_CHAT_ID=123456789          # Only this chat may command the bot

# ── Zerodha Kite Connect ───────────────────────────────────
# From https://developers.kite.trade (app must be a Kite Connect app)
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
# Regenerated daily via `python generate_kite_token.py` (leave blank initially)
KITE_ACCESS_TOKEN=

# ── DhanHQ ──────────────────────────────────────────────────
# From https://dhanhq.co  →  My Profile → DhanHQ Trading APIs
DHAN_CLIENT_ID=your_dhan_client_id
DHAN_ACCESS_TOKEN=your_dhan_access_token   # Static token, valid ~30 days

# ── Dhan token via AWS SSM (optional — production/EC2 only) ─
# When DHAN_TOKEN_SSM_PARAM is set, the bot fetches the Dhan token from AWS
# SSM Parameter Store (SecureString) instead of DHAN_ACCESS_TOKEN above —
# leave DHAN_ACCESS_TOKEN blank in that case. Requires an EC2 instance role
# with ssm:GetParameter on the param (see deploy/iam-policy.json); no AWS
# keys are stored on disk. Unset (default) = local dev, unchanged behavior.
# DHAN_TOKEN_SSM_PARAM=/nxbagger/DHAN_ACCESS_TOKEN
# DHAN_SSM_REGION=ap-south-1   # defaults to AWS_REGION/AWS_DEFAULT_REGION/ap-south-1

# ── Engine tuning ──────────────────────────────────────────
POLL_INTERVAL_SECONDS=15     # PnL check frequency (keep >= 5 to respect rate limits)
ENABLE_ZERODHA=true
ENABLE_DHAN=true
DB_PATH=pnl_sentinel.db

# ── Onboarding images (optional) ───────────────────────────
# Dir the bot reads onboarding images from (hero.jpg shown on /start).
# ONBOARDING_IMG_DIR=../brand/onboarding

# ── E2E test harness (dev only — see docs/testing-telegram.md) ─
# Telethon USER client on a DEDICATED test account. Secrets — never commit.
# TG_TEST_API_ID=            # from https://my.telegram.org/apps
# TG_TEST_API_HASH=
# TG_TEST_SESSION=           # from e2e/session_gen.py
# BOT_USERNAME=stockpulse_official_bot
